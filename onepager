     ============================================================ -->
<div class="sec-label" id="desktop">roles.desktop — click a folder to open</div>
<div class="desktop">

  <!-- LEFT SIDEBAR — first 5 folders -->
  <div class="sidebar sidebar-left" id="sidebar">

    <button class="folder-btn" id="btn-writer" onclick="tog('writer')" aria-label="Open Writer window">
      <div class="folder-icon"><svg viewBox="0 0 36 30" fill="none"><path d="M2 8C2 6.9 2.9 6 4 6H14L17 3H32C33.1 3 34 3.9 34 5V8H2Z" fill="#F4614A" opacity=".45"/><rect x="2" y="8" width="32" height="19" rx="2" fill="#F4614A" opacity=".82"/></svg></div>
      <span class="folder-label">Writer</span>
    </button>

    <button class="folder-btn" id="btn-blogger" onclick="tog('blogger')" aria-label="Open Blogger window">
      <div class="folder-icon"><svg viewBox="0 0 36 30" fill="none"><path d="M2 8C2 6.9 2.9 6 4 6H14L17 3H32C33.1 3 34 3.9 34 5V8H2Z" fill="#3EC8D4" opacity=".45"/><rect x="2" y="8" width="32" height="19" rx="2" fill="#3EC8D4" opacity=".82"/></svg></div>
      <span class="folder-label">Blogger</span>
    </button>

    <button class="folder-btn" id="btn-lecturer" onclick="tog('lecturer')" aria-label="Open Lecturer window">
      <div class="folder-icon"><svg viewBox="0 0 36 30" fill="none"><path d="M2 8C2 6.9 2.9 6 4 6H14L17 3H32C33.1 3 34 3.9 34 5V8H2Z" fill="#F2B8B0" opacity=".55"/><rect x="2" y="8" width="32" height="19" rx="2" fill="#F2B8B0" opacity=".9"/></svg></div>
